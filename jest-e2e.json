{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "./",
  "testRegex": ".*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": ["**/*.(t|j)s"],
  "moduleDirectories": ["node_modules", "src"],
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1",
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
